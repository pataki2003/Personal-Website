{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/contact",
      "destination": "/kapcsolat",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/kapcsolat",
      "permanent": true
    },
    {
      "source": "/en/contact.html",
      "destination": "/en/contact",
      "permanent": true
    }
  ]
}
